    "adapter": {
      "kind": "structured",
      "context": [
        {
          "name": "image_items",
          "input": "images",
          "transform": {
            "name": "collect_counted_inputs",
            "count": {"input": "inputcount"},
            "max_count": 9,
            "extra_input_pattern": "image_{index}",
            "item_transform": "image_batches"
          }
        },
        {
          "name": "input_image_count",
          "context": "image_items",
          "transform": "count"
        },
        {
          "name": "resolved_size",
          "input": "size",
          "transform": {
            "name": "resolve_custom_size",
            "model": {"input": "model"},
            "custom_width": {"input": "custom_width"},
            "custom_height": {"input": "custom_height"},
            "has_input_images": {"context": "input_image_count"},
            "enable_sequential": {"input": "enable_sequential"}
          }
        },
        {
          "name": "uploaded_urls",
          "context": "image_items",
          "transform": {
            "name": "upload_media_list",
            "media_type": "IMAGE",
            "input_name": "images",
            "file_name_prefix": "wan27_image_{index}",
            "total_pixels": 64000000,
            "max_size": 20971520
          }
        },
        {
          "name": "parsed_bbox_list",
          "input": "bbox_list",
          "transform": {
            "name": "parse_bbox_list",
            "image_count": {"context": "input_image_count"}
          }
        },
        {
          "name": "parsed_color_palette",
          "input": "color_palette",
          "transform": {
            "name": "parse_color_palette",
            "enable_sequential": {"input": "enable_sequential"}
          }
        }
      ],
      "validators": [
        {
          "name": "max_count",
          "value": {"context": "image_items"},
          "max": 9,
          "message": "Wan2.7 Image supports at most 9 input images"
        },
        {
          "name": "int_range",
          "value": {"input": "n"},
          "min": 1,
          "max": 12,
          "when": {"source": "input", "key": "enable_sequential", "op": "is_true"},
          "message": "n must be between 1 and 12 when enable_sequential=true"
        },
        {
          "name": "int_range",
          "value": {"input": "n"},
          "min": 1,
          "max": 4,
          "when": {"source": "input", "key": "enable_sequential", "op": "is_false"},
          "message": "n must be between 1 and 4 when enable_sequential=false"
        },
        {
          "name": "require_any_non_empty",
          "refs": [
            {"input": "prompt"},
            {"context": "uploaded_urls"}
          ],
          "message": "At least a prompt or one input image is required"
        }
      ],
      "payload": [
        {
          "field": "model",
          "input": "model"
        },
        {
          "field": "size",
          "context": "resolved_size"
        },
        {
          "field": "n",
          "input": "n"
        },
        {
          "field": "watermark",
          "input": "watermark"
        },
        {
          "field": "prompt",
          "input": "prompt",
          "when": {"source": "input", "key": "prompt", "op": "non_empty"}
        },
        {
          "field": "urls",
          "context": "uploaded_urls",
          "when": {"source": "context", "key": "uploaded_urls", "op": "non_empty"}
        },
        {
          "field": "enable_sequential",
          "const": true,
          "when": {"source": "input", "key": "enable_sequential", "op": "is_true"}
        },
        {
          "field": "thinking_mode",
          "input": "thinking_mode",
          "when": {
            "all": [
              {"source": "input", "key": "enable_sequential", "op": "is_false"},
              {"source": "context", "key": "uploaded_urls", "op": "empty"}
            ]
          }
        },
        {
          "field": "bbox_list",
          "context": "parsed_bbox_list",
          "when": {"source": "context", "key": "parsed_bbox_list", "op": "exists"}
