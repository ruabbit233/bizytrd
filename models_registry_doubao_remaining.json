  {
    "internal_name": "Seedance_2_0_REF_API",
    "class_name": "Seedance_2_0_REF_API",
    "display_name": "Seedance 2.0 References To Video",
    "category": "BizyTRD/Doubao",
    "model_name": "seedance-2-0",
    "endpoint_category": "Reference To Video",
    "output_type": "video",
    "params": [
      {
        "name": "prompt",
        "type": "STRING",
        "required": true,
        "multiline": true,
        "default": "",
        "description": "视频生成提示词。描述希望生成的视频内容。",
        "fieldKey": "prompt"
      },
      {
        "name": "ratio",
        "type": "LIST",
        "required": true,
        "options": [
          "16:9",
          "4:3",
          "3:4",
          "9:16"
        ],
        "description": "视频宽高比。",
        "fieldKey": "ratio",
        "default": "16:9"
      },
      {
        "name": "duration",
        "type": "LIST",
        "required": true,
        "options": [
          5,
          10,
          15
        ],
        "description": "视频时长，单位秒。",
        "fieldKey": "duration",
        "default": 5
      },
      {
        "name": "images",
        "type": "IMAGE",
        "required": false,
        "description": "参考图，最多 4 张。旧节点对单张图片限制为 10MB。",
        "fieldKey": "images",
        "maxInputNum": 4
      }
    ]
  },
  {
    "internal_name": "Seedance_2_0_JIMENG_DREAMACTOR_API",
    "class_name": "Seedance_2_0_JIMENG_DREAMACTOR_API",
    "display_name": "Jimeng DreamActor M20",
    "category": "BizyTRD/Doubao",
    "model_name": "dreamactor-2-0",
    "endpoint_category": "Dream Actor",
    "output_type": "video",
    "params": [
      {
        "name": "image",
        "type": "IMAGE",
        "required": true,
        "description": "人物参考图。旧节点限制压缩后图片小于 4.7MB。",
        "fieldKey": "image"
      },
      {
        "name": "video",
        "type": "VIDEO",
        "required": true,
        "description": "动作参考视频。旧节点校验视频不超过 30 秒，分辨率范围为 200x200 到 2048x1440。",
        "fieldKey": "video"
      },
      {
        "name": "duration",
        "type": "FLOAT",
        "hidden": true,
        "description": "动作参考视频时长，单位秒。通过 doubao.video_duration 从 video 输入对象读取。",
        "fieldKey": "duration",
        "valueHook": "doubao.video_duration"
      }
    ]
  }
