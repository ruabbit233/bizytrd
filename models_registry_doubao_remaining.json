[
  {
    "internal_name": "Seedance_1_5_T2V_API",
    "class_name": "Seedance_1_5_T2V_API",
    "display_name": "Seedance 1.5 Text To Video",
    "category": "BizyTRD/Doubao",
    "model_name": "seedance-1-5",
    "endpoint_category": "Text To Video",
    "output_type": "video",
    "params": [
      {
        "name": "prompt",
        "type": "STRING",
        "required": true,
        "multiline": true,
        "default": "",
        "description": "视频生成提示词。描述希望生成的视频内容。Seedance 1.5 Pro 支持生成与画面同步的声音，建议将对话部分置于双引号内。",
        "fieldKey": "prompt"
      },
      {
        "name": "resolution",
        "type": "LIST",
        "required": true,
        "options": [
          "480p",
          "720p",
          "1080p"
        ],
        "description": "分辨率+比例共同决定视频尺寸，具体尺寸请参考官方文档说明。",
        "fieldKey": "resolution",
        "default": "1080p"
      },
      {
        "name": "ratio",
        "type": "LIST",
        "required": true,
        "options": [
          "16:9",
          "4:3",
          "1:1",
          "3:4",
          "9:16",
          "21:9",
          "adaptive"
        ],
        "description": "视频宽高比。`adaptive` 表示自动匹配。",
        "fieldKey": "ratio",
        "default": "adaptive"
      },
      {
        "name": "duration",
        "type": "INT",
        "required": true,
        "min": 4,
        "max": 12,
        "description": "视频时长，单位秒。",
        "fieldKey": "duration",
        "default": 12
      },
      {
        "name": "fps",
        "type": "LIST",
        "required": true,
        "options": [
          24
        ],
        "description": "帧率固定为 24。",
        "fieldKey": "fps",
        "default": 24
      },
      {
        "name": "camerafixed",
        "type": "BOOLEAN",
        "required": true,
        "description": "平台可能在提示词中追加固定摄像机指令，效果不保证。",
        "fieldKey": "camerafixed",
        "default": false
      },
      {
        "name": "generate_audio",
        "type": "BOOLEAN",
        "required": true,
        "description": "是否生成与画面同步的声音。开启后可能影响计费。",
        "fieldKey": "generateAudio",
        "default": false
      },
      {
        "name": "seed",
        "type": "INT",
        "required": true,
        "min": -1,
        "max": 2147483647,
        "default": -1,
        "description": "随机种子。-1 表示随机。",
        "fieldKey": "seed"
      },
      {
        "name": "watermark",
        "type": "BOOLEAN",
        "hidden": true,
        "default": false,
        "fieldKey": "watermark"
      }
    ]
  },
