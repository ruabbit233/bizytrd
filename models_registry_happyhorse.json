[
  {
    "internal_name": "HappyHorse_1_0_T2V_API",
    "class_name": "HappyHorse_1_0_T2V_API",
    "display_name": "HappyHorse 1.0 Text To Video",
    "category": "BizyTRD/HappyHorse",
    "model_name": "happyhorse-1-0-t2v",
    "endpoint_category": "Text To Video",
    "output_type": "video",
    "params": [
      {
        "name": "prompt",
        "type": "STRING",
        "required": true,
        "multiline": true,
        "default": "",
        "description": "文本提示词，用于描述期望生成的视频内容。",
        "fieldKey": "prompt",
        "sendIf": "non_empty"
      },
      {
        "name": "resolution",
        "type": "LIST",
        "required": false,
        "fieldKey": "resolution",
        "options": [
          "720P",
          "1080P"
        ],
        "default": "1080P",
        "description": "输出分辨率。"
      },
      {
        "name": "ratio",
        "type": "LIST",
        "required": false,
        "fieldKey": "ratio",
        "options": [
          "1:1",
          "4:3",
          "3:4",
          "9:16",
          "16:9"
        ],
        "default": "16:9",
        "description": "输出宽高比。"
      },
      {
        "name": "duration",
        "type": "INT",
        "required": false,
        "fieldKey": "duration",
        "default": 5,
        "min": 3,
        "max": 15,
        "step": 1,
        "description": "视频时长，单位秒。"
      },
      {
        "name": "watermark",
        "type": "BOOLEAN",
        "required": false,
        "fieldKey": "watermark",
        "default": false,
        "description": "是否在生成的视频上添加水印标识。水印位于视频右下角，文案固定为\"Happy Horse\"。"
      },
      {
        "name": "seed",
        "type": "INT",
        "required": false,
        "fieldKey": "seed",
        "default": -1,
        "min": -1,
        "max": 2147483647,
        "step": 1,
        "description": "为-1时系统自动生成随机种子。若需提升生成结果的可复现性，建议固定seed值。",
        "sendIf": "gte_zero"
      },
      {
        "name": "request_model",
        "hidden": true,
        "default": "happyhorse-1.0-t2v",
        "fieldKey": "model"
      }
    ]
  },
