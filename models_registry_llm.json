[
  {
    "internal_name": "LLM_gemini_3_flash_preview_API",
    "class_name": "LLM_gemini_3_flash_preview_API",
    "display_name": "gemini-3-flash-preview LLM",
    "category": "BizyTRD/LLM",
    "model_name": "gemini-3-flash-preview",
    "endpoint_category": "large-language-models",
    "output_type": "text",
    "params": [
      {
        "name": "channel",
        "type": "LIST",
        "required": true,
        "options": [
          "base",
          "official"
        ],
        "description": "模型供应渠道，official 表示官方模型，base 表示三方模型。前者稳定性更好价格更高，后者价格更低但可能存在波动。",
        "fieldKey": "channel",
        "default": "official"
      },
      {
        "name": "model",
        "type": "STRING",
        "required": true,
        "fieldKey": "model",
        "default": "gemini-3-flash-preview",
        "internal": true,
        "description": "模型标识。"
      },
      {
        "name": "system_prompt",
        "type": "STRING",
        "required": true,
        "fieldKey": "system_prompt",
        "default": "你是一个有帮助的AI助手。",
        "multiline": true,
        "description": "系统提示词。"
      },
      {
        "name": "user_prompt",
        "type": "STRING",
        "required": true,
        "fieldKey": "user_prompt",
        "default": "你好，请介绍一下你自己。",
        "multiline": true,
        "description": "用户提示词。"
      },
      {
        "name": "max_tokens",
        "type": "INT",
        "required": true,
        "fieldKey": "max_tokens",
        "default": 32768,
        "min": 1,
        "max": 65536,
        "description": "生成文本的最大长度，单位为 token。"
      },
      {
        "name": "temperature",
        "type": "FLOAT",
        "required": true,
        "fieldKey": "temperature",
        "default": 1.0,
        "min": 0.0,
        "max": 2.0,
        "step": 0.01,
        "description": "采样温度，值越大生成结果越随机。"
      },
      {
        "name": "tools",
        "type": "STRING",
        "required": false,
        "fieldKey": "tools",
        "default": "[]",
        "forceInput": true,
        "valueHook": "common.json_loads",
        "description": "来自 LLM Tool Config 节点的工具配置。"
      }
    ]
  },
