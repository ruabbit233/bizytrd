      },
      {
        "name": "model",
        "type": "LIST",
        "required": true,
        "fieldKey": "model",
        "options": [
          "veo3.1-fast",
          "veo3.1-pro"
        ],
        "default": "veo3.1-fast",
        "description": "模型版本。"
      },
      {
        "name": "aspect_ratio",
        "type": "LIST",
        "required": false,
        "fieldKey": "aspect_ratio",
        "options": [
          "9:16",
          "16:9"
        ],
        "default": "16:9",
        "description": "输出宽高比。"
      },
      {
        "name": "resolution",
        "type": "LIST",
        "required": false,
        "fieldKey": "resolution",
        "options": [
          "720p",
          "1080p",
          "4k"
        ],
        "default": "1080p",
        "description": "输出分辨率。"
      }
    ]
  },
